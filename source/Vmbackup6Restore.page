<!-- run jquery/javascript -->
<script type="text/javascript">
  $(function() {
    // Set up filetree picker for backup location
    $('#backup_location_restore').click(function() {
      var el = this;
      var startDir = $(el).val();
      if (!startDir || startDir === '') startDir = '/mnt/';
      // Strip to directory if it looks like a file path
      if (startDir.slice(-1) !== '/') startDir = startDir.substring(0, startDir.lastIndexOf('/') + 1);
      if (startDir === '') startDir = '/mnt/';
      $.filetree_open({
        root: '/mnt/',
        filter: 'NO_FILES_FILTER',
        folderonly: true,
        select: function(file) {
          $(el).val(file).trigger('change');
        },
        start: startDir
      });
    });

    // Scan button
    $('#btn_scan').on('click', function() {
      var backup_location = $('#backup_location_restore').val().trim();
      if (!backup_location) {
        swal('Error', 'Please enter a backup location.', 'error');
        return;
      }
      $('#scan_results').html('<i class="fa fa-spinner fa-spin restore_status_spinner"></i> Scanning...');
      $('#vm_select_all_row').hide();
      $.post('/plugins/vmbackup/include/restore.php', {
        action: 'scan',
        backup_location: backup_location
      }, function(data) {
        if (data.error) {
          swal('Scan Error', data.error, 'error');
          $('#scan_results').html('');
          return;
        }
        var vmCount = Object.keys(data.vms).length;
        if (vmCount === 0) {
          $('#scan_results').html('<p>No backup versions found at this location.</p>');
          return;
        }
        renderVmList(data.vms);
      }, 'json').fail(function() {
        swal('Error', 'Scan request failed. Check the backup location and server connectivity.', 'error');
        $('#scan_results').html('');
      });
    });

    // Select All / Deselect All
    $(document).on('click', '#link_select_all', function(e) {
      e.preventDefault();
      $('#vm_list_table input[type=checkbox]').prop('checked', true);
      updateRestoreButton();
    });
    $(document).on('click', '#link_deselect_all', function(e) {
      e.preventDefault();
      $('#vm_list_table input[type=checkbox]').prop('checked', false);
      updateRestoreButton();
    });

    // VM checkbox change — update button state
    $(document).on('change', '.vm_restore_checkbox', function() {
      updateRestoreButton();
    });

    // Confirmation checkbox controls Restore button
    $('#confirm_restore').on('change', function() {
      updateRestoreButton();
    });

    // Restore Now button
    $('#btn_restore_now').on('click', function() {
      var selectedVms = getSelectedVms();
      if (selectedVms.length === 0) {
        swal('No VMs Selected', 'Please select at least one VM to restore.', 'warning');
        return;
      }
      if (!$('#confirm_restore').is(':checked')) {
        swal('Confirmation Required', 'Please check the confirmation checkbox before restoring.', 'warning');
        return;
      }
      var vmList = selectedVms.map(function(v) { return v.vm + ' @ ' + v.version; }).join('\n');
      swal({
        title: 'Confirm Restore',
        text: 'The following VMs will be restored:\n\n' + vmList + '\n\nCurrent disk images will be backed up to .pre_restore_tmp before overwriting.',
        type: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'Yes, Restore',
        cancelButtonText: 'Cancel',
        closeOnConfirm: true
      }, function(confirmed) {
        if (confirmed) {
          startRestore(selectedVms);
        }
      });
    });

    // Stop Restore button
    $('#btn_stop_restore').on('click', function() {
      swal({
        title: 'Stop Restore?',
        text: 'A stop signal will be sent. Files already copied will be reverted to their pre-restore state using .pre_restore_tmp backups.',
        type: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'Yes, Stop',
        cancelButtonText: 'Cancel',
        closeOnConfirm: true
      }, function(confirmed) {
        if (confirmed) {
          $.post('/plugins/vmbackup/include/restore.php', {action: 'stop_restore'}, function(data) {
            if (data.error) {
              swal('Error', data.error, 'error');
            } else {
              swal('Stop Signal Sent', 'The restore will stop at the next checkpoint.', 'info');
            }
          }, 'json');
        }
      });
    });

    // If restore is running on page load, show status and start polling
    <?php if ($restore_running): ?>
    $('#restore_status_section').show();
    $('#btn_stop_restore').show();
    $('#btn_restore_now').prop('disabled', true);
    startStatusPolling();
    <?php endif; ?>
  });

  // Build the VM selection table from scan results
  function renderVmList(vms) {
    var html = '<table id="vm_list_table" width="100%" cellspacing="0">';
    html += '<thead><tr><th style="width:30px"></th><th>VM</th><th>Version to Restore</th></tr></thead>';
    html += '<tbody>';

    $.each(vms, function(vmName, versions) {
      var cbId = 'cb_vm_' + vmName.replace(/[^a-zA-Z0-9_]/g, '_');
      var selId = 'sel_vm_' + vmName.replace(/[^a-zA-Z0-9_]/g, '_');
      html += '<tr class="vm_select_row">';
      html += '<td><input type="checkbox" id="' + cbId + '" class="vm_restore_checkbox" data-vm="' + escHtml(vmName) + '" data-sel="' + selId + '" checked></td>';
      html += '<td><label for="' + cbId + '">' + escHtml(vmName) + '</label></td>';
      html += '<td><select id="' + selId + '" class="vm_version_select" data-vm="' + escHtml(vmName) + '">';
      $.each(versions, function(i, v) {
        var badge = '';
        if (v.format === 'zstd') {
          badge += '<span class="vm_format_badge badge_zstd">[zstd]</span>';
        } else if (v.format === 'tar_gz') {
          badge += '<span class="vm_format_badge badge_tar_gz">[tar.gz]</span>';
        } else {
          badge += '<span class="vm_format_badge badge_uncompressed">[uncompressed]</span>';
        }
        var completeness = v.complete ? ' \u2713' : ' \u26a0 incomplete';
        var nvramNote = (!v.has_nvram) ? ' (no nvram)' : '';
        var label = v.display + completeness + nvramNote;
        html += '<option value="' + escHtml(v.timestamp) + '">' + escHtml(label) + '</option>';
      });
      html += '</select></td>';
      html += '</tr>';
    });

    html += '</tbody></table>';

    $('#scan_results').html(html);
    $('#vm_select_all_row').show();
    updateRestoreButton();
  }

  // Collect selected VM/version pairs
  function getSelectedVms() {
    var selected = [];
    $('.vm_restore_checkbox:checked').each(function() {
      var vmName = $(this).data('vm');
      var selId = $(this).data('sel');
      var version = $('#' + selId).val();
      selected.push({vm: vmName, version: version});
    });
    return selected;
  }

  // Enable/disable Restore button based on selection and confirmation
  function updateRestoreButton() {
    var anyChecked = ($('.vm_restore_checkbox:checked').length > 0);
    var confirmed = $('#confirm_restore').is(':checked');
    $('#btn_restore_now').prop('disabled', !(anyChecked && confirmed));
  }

  // Start the restore via AJAX
  function startRestore(selectedVms) {
    $('#btn_restore_now').prop('disabled', true);
    $.post('/plugins/vmbackup/include/restore.php', {
      action: 'restore_now',
      backup_location: $('#backup_location_restore').val().trim(),
      vm_selections: JSON.stringify(selectedVms),
      dry_run: $('#dry_run_restore').val()
    }, function(data) {
      if (data.error) {
        swal('Error', data.error, 'error');
        updateRestoreButton();
        return;
      }
      // Show status section and begin polling
      $('#restore_status_section').show();
      $('#btn_stop_restore').show();
      startStatusPolling();
    }, 'json').fail(function() {
      swal('Error', 'Failed to start restore. Please check server logs.', 'error');
      updateRestoreButton();
    });
  }

  // Status polling
  var statusPoller = null;

  function startStatusPolling() {
    if (statusPoller) return; // already polling
    statusPoller = setInterval(function() {
      $.get('/plugins/vmbackup/include/restore.php', {action: 'get_status'}, function(data) {
        updateStatusDisplay(data);
        if (!data.running) {
          stopStatusPolling();
          $('#btn_restore_now').prop('disabled', false);
          $('#btn_stop_restore').hide();
          updateRestoreButton();
          swal('Restore Complete', 'The restore operation has finished. Check the log below for details.', 'success');
        }
      }, 'json');
    }, 2000);
  }

  function stopStatusPolling() {
    if (statusPoller) {
      clearInterval(statusPoller);
      statusPoller = null;
    }
  }

  // Update the status display table and log panel
  function updateStatusDisplay(data) {
    // Parse status lines: TIMESTAMP|VM|STATE|MESSAGE
    var rows = '';
    if (data.status && data.status.length > 0) {
      $.each(data.status, function(i, line) {
        var parts = line.split('|');
        var ts  = parts[0] || '';
        var vm  = parts[1] || '';
        var state = parts[2] || '';
        var msg = parts[3] || '';
        // Extract time portion only (HH:MM:SS)
        var timeStr = ts.length >= 8 ? ts.slice(-8) : ts;
        rows += '<tr>';
        rows += '<td>' + escHtml(vm) + '</td>';
        rows += '<td>' + escHtml(state) + (msg ? ': ' + escHtml(msg) : '') + '</td>';
        rows += '<td>' + escHtml(timeStr) + '</td>';
        rows += '</tr>';
      });
    } else {
      rows = '<tr><td colspan="3" style="color:#888">No status information yet...</td></tr>';
    }
    $('#restore_status_table tbody').html(rows);

    // Update log
    if (data.log !== undefined) {
      var $log = $('#restore_log_pre');
      $log.text(data.log);
      // Auto-scroll to bottom
      $log.scrollTop($log[0].scrollHeight);
    }
  }

  // HTML escape helper
  function escHtml(str) {
    return $('<div>').text(str).html();
  }
</script>

